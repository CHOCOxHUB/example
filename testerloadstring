if not game:IsLoaded() then
    game.Loaded:Wait()
end

-- Daftar ID Game
local gameVibeDungeonID = 93978595733734
local gameK2ClimbingID  = 124853293317687

local function MuatScript()
    if game.PlaceId == gameVibeDungeonID then
        -- Load script khusus Vibe Dungeon
        loadstring(game:HttpGet("https://raw.githubusercontent.com/CHOCOxHUB/example/refs/heads/main/CHOCOxHUB-ViolenceDistrict.lua"))()
        
    elseif game.PlaceId == gameK2ClimbingID then
        -- Load script khusus K2 Climbing (Silakan sesuaikan nama filenya jika berbeda)
        loadstring(game:HttpGet("https://raw.githubusercontent.com/CHOCOxHUB/example/refs/heads/main/CHOCOxHUB-K2-Climbing.lua"))()
        
    else
        -- Script universal
        loadstring(game:HttpGet("https://raw.githubusercontent.com/CHOCOxHUB/example/refs/heads/main/CHOCO-X-HUB-Auto-Walk.lua"))()
    end
end

pcall(MuatScript)
